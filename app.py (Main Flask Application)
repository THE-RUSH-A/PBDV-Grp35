@app.route('/student/matching')
@login_required
def roommate_matching():
    # Get all other students
    other_students = User.query.filter(User.id != current_user.id, User.role == 'student').all()
    
    # Calculate compatibility scores
    matches = []
    current_prefs = current_user.preferences
    
    for student in other_students:
        if student.preferences:
            score = calculate_compatibility(current_prefs, student.preferences)
            if score > 50:  # Only show matches with >50% compatibility
                # Check if match request exists
                existing_request = MatchRequest.query.filter(
                    ((MatchRequest.sender_id == current_user.id) & (MatchRequest.receiver_id == student.id)) |
                    ((MatchRequest.sender_id == student.id) & (MatchRequest.receiver_id == current_user.id))
                ).first()
                
                matches.append({
                    'user': student,
                    'score': score,
                    'request_status': existing_request.status if existing_request else None,
                    'request_id': existing_request.id if existing_request else None
                })
    
    # Sort by score descending
    matches.sort(key=lambda x: x['score'], reverse=True)
    
    return render_template('student/roommate-matching.html', matches=matches)

def calculate_compatibility(prefs1, prefs2):
    """Calculate compatibility score between two users"""
    score = 0
    total_weight = 0
    
    # Gender preference (if specified)
    if prefs1.preferred_gender and prefs2.preferred_gender:
        if prefs1.preferred_gender == prefs2.preferred_gender or prefs1.preferred_gender == 'Any' or prefs2.preferred_gender == 'Any':
            score += 10
        total_weight += 10
    
    # Sleep schedule
    if prefs1.sleep_schedule and prefs2.sleep_schedule:
        if prefs1.sleep_schedule == prefs2.sleep_schedule:
            score += 15
        total_weight += 15
    
    # Study habits
    if prefs1.study_habits and prefs2.study_habits:
        if prefs1.study_habits == prefs2.study_habits:
            score += 15
        total_weight += 15
    
    # Cleanliness (within 2 points)
    if prefs1.cleanliness and prefs2.cleanliness:
        if abs(prefs1.cleanliness - prefs2.cleanliness) <= 2:
            score += 10
        total_weight += 10
    
    # Guest policy
    if prefs1.guest_policy and prefs2.guest_policy:
        if prefs1.guest_policy == prefs2.guest_policy:
            score += 10
        total_weight += 10
    
    # Lifestyle factors
    lifestyle_factors = ['smoking', 'drinking', 'pets']
    for factor in lifestyle_factors:
        val1 = getattr(prefs1, factor)
        val2 = getattr(prefs2, factor)
        if val1 == val2:
            score += 10
        total_weight += 10
    
    # Budget overlap
    if prefs1.budget_min and prefs1.budget_max and prefs2.budget_min and prefs2.budget_max:
        if (prefs1.budget_min <= prefs2.budget_max and prefs2.budget_min <= prefs1.budget_max):
            score += 10
        total_weight += 10
    
    return (score / total_weight * 100) if total_weight > 0 else 0

@app.route('/student/send-match-request/<int:receiver_id>', methods=['POST'])
@login_required
def send_match_request(receiver_id):
    receiver = User.query.get_or_404(receiver_id)
    
    # Check if request already exists
    existing = MatchRequest.query.filter(
        ((MatchRequest.sender_id == current_user.id) & (MatchRequest.receiver_id == receiver_id)) |
        ((MatchRequest.sender_id == receiver_id) & (MatchRequest.receiver_id == current_user.id))
    ).first()
    
    if existing:
        flash('A match request already exists with this user', 'warning')
    else:
        # Calculate compatibility
        score = calculate_compatibility(current_user.preferences, receiver.preferences)
        
        # Create request
        request = MatchRequest(
            sender_id=current_user.id,
            receiver_id=receiver_id,
            compatibility_score=score
        )
        db.session.add(request)
        
        # Create notification
        notification = Notification(
            user_id=receiver_id,
            type='match_request',
            title='New Match Request',
            message=f'{current_user.first_name} {current_user.last_name} sent you a match request',
            related_id=request.id
        )
        db.session.add(notification)
        db.session.commit()
        
        flash('Match request sent successfully!', 'success')
    
    return redirect(url_for('roommate_matching'))

